{
  "name": "tracklist-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Express + TypeScript API server for Tracklist (web + mobile)",
  "scripts": {
    "dev": "nodemon --watch './**/*.ts' --exec 'ts-node --project tsconfig.json' server.ts",
    "build": "tsc",
    "start": "node dist/backend/server.js"
  },
  "dependencies": {
    "@tracklist/spotify-client": "file:../packages/spotify-client",
    "bottleneck": "^2.19.5",
    "ioredis": "^5.10.1",
    "@supabase/supabase-js": "^2.105.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.1",
    "http-proxy-middleware": "^3.0.3",
    "next-auth": "^4.24.14"
  },
  "overrides": {
    "uuid": "^14.0.0",
    "postcss": "^8.5.10",
    "fast-xml-parser": "^5.7.0",
    "basic-ftp": "^5.2.5",
    "follow-redirects": "^1.15.12",
    "next": "^16.2.4"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.17",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
