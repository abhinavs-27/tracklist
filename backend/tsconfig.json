{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "moduleResolution": "node",
    "ignoreDeprecations": "5.0",
    "baseUrl": "..",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "./**/*.ts",
    "./types/**/*.d.ts",
    "../lib/user-search-directory.ts",
    "../lib/ratings.ts",
    "../lib/redis-client.ts",
    "../lib/redis-error-handler.ts",
    "../lib/discover-redis.ts",
    "../lib/feed/legacy-feed-bundle.ts",
    "../types/index.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
